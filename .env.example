# Ceylon Canvas - Environment Variables
# Copy this file to .env and fill in your values

# ============ REQUIRED ============

# JWT Secret (generate a random string: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Backend URL (your domain or IP)
REACT_APP_BACKEND_URL=https://ceyloncanvas.live

# ============ PAYMENTS ============

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ============ EMAIL ============

# Resend (get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key
SENDER_EMAIL=noreply@yourdomain.com

# ============ STORAGE (Optional) ============

# Emergent Key (for image uploads - get from Emergent platform)
EMERGENT_KEY=your_emergent_key_if_using

# ============ DATABASE ============
# These are set automatically in docker-compose
# Only change if using external MongoDB (e.g., MongoDB Atlas)

# MONGO_URL=mongodb://mongodb:27017
# DB_NAME=ceylon_canvas

# ============ FOR MONGODB ATLAS (Optional) ============
# If you prefer managed MongoDB, use Atlas:
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/ceylon_canvas?retryWrites=true&w=majority
